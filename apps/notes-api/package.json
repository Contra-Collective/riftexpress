{
  "name": "ingenium-app-notes-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reference Ingenium application: a notes service with users, tags, and full-text search backed by SQLite.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ingenium": "*",
    "better-sqlite3": "^11.5.0",
    "zod": "^3.23.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0"
  }
}
