{
  "name": "riftexpress-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*",
    "benchmarks"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "bench": "node --experimental-strip-types benchmarks/hello.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
