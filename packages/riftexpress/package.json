{
  "name": "riftexpress",
  "version": "0.0.1",
  "description": "Express DX, Hono/Fastify throughput. A Node.js HTTP framework.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["http", "express", "framework", "router", "fast"],
  "license": "MIT",
  "peerDependencies": {
    "zod": "^4.4.3",
    "ws": "^8.18.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true },
    "ws": { "optional": true }
  },
  "devDependencies": {
    "zod": "^4.4.3",
    "ws": "^8.18.0",
    "@types/ws": "^8.5.0"
  }
}
