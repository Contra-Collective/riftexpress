{
  "name": "riftexpress-compat",
  "version": "0.0.1",
  "description": "Express middleware compatibility shim for RiftExpress.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "express",
    "compat",
    "riftexpress",
    "middleware"
  ],
  "license": "MIT",
  "peerDependencies": {
    "riftexpress": "*"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^2.1.0",
    "@types/passport": "^1.0.16",
    "body-parser": "^2.2.2",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "vitest": "^4.1.6"
  }
}
